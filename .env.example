# Site Configuration
NEXT_PUBLIC_SITE_URL=https://perspectivehealthiowa.com
NEXT_PUBLIC_SITE_NAME="Perspective Health Iowa"

# Contact Form (configure your preferred email service)
# Option 1: Resend
RESEND_API_KEY=your_resend_api_key_here
CONTACT_EMAIL=info@perspectivehealthiowa.com

# Option 2: SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Maps API (optional, for map embed)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Chatbot (disabled by default — set to "true" to render the chat widget on the site)
# Pending: BAA decision with Anthropic, or switch to a different chatbot vendor.
NEXT_PUBLIC_CHATBOT_ENABLED=false

# Anthropic API key — only used when chatbot is enabled
ANTHROPIC_API_KEY=your_anthropic_api_key_here
